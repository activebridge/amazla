    "appId": 1107663,
    "appName": "Minimal",
    "appType": "watchface",
    "version": {
      "code": 1,
      "name": "1.0.0"
    },
    "icon": "icon.png",
    "vender": "galulex",
    "description": "Minimal on steroids. A clean, distraction-free watchface that packs everything you need — time, heart rate, steps, calories, battery, PAI, standing, weather, moon phase, and more — all arranged around the dial like a precision instrument. Tap any indicator to dive deeper. Less clutter, more clarity."
  },
